{
  "info": {
    "name": "Attendify API",
    "description": "Complete Attendify REST API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api" },
    { "key": "adminToken",   "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "userId",       "value": "" },
    { "key": "recordId",     "value": "" },
    { "key": "qrToken",      "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@test.com\",\n  \"password\": \"password123\",\n  \"studentId\": \"CS001\",\n  \"department\": \"Computer Science\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.collectionVariables.set('adminToken', pm.response.json().token);"]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@attendify.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login (Student)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.collectionVariables.set('studentToken', pm.response.json().token);"]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@attendify.com\",\n  \"password\": \"Student@123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/auth/update-profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Updated\",\n  \"department\": \"Software Engineering\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Student@123\",\n  \"newPassword\": \"NewPass@456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/attendance/mark",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2024-04-21\",\n  \"status\": \"present\",\n  \"subject\": \"Mathematics\",\n  \"note\": \"On time\"\n}"
            }
          }
        },
        {
          "name": "Get My Attendance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance/my?month=2024-04",
              "query": [{ "key": "month", "value": "2024-04" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }]
          }
        },
        {
          "name": "Get Today Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/attendance/today",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?role=student&search=alice",
              "query": [
                { "key": "role",   "value": "student" },
                { "key": "search", "value": "alice" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"department\": \"Electronics\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Get All Attendance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/attendance?month=2024-04",
              "query": [{ "key": "month", "value": "2024-04" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Bulk Mark Attendance",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/attendance/bulk-mark",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userIds\": [\"USER_ID_1\", \"USER_ID_2\"],\n  \"date\": \"2024-04-21\",\n  \"status\": \"present\",\n  \"subject\": \"General\"\n}"
            }
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/export/csv?month=2024-04",
              "query": [{ "key": "month", "value": "2024-04" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Export PDF",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/export/pdf?month=2024-04",
              "query": [{ "key": "month", "value": "2024-04" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "QR Code",
      "item": [
        {
          "name": "Generate QR",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.collectionVariables.set('qrToken', pm.response.json().session.token);"]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/qr/generate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Mathematics\",\n  \"expiresInMinutes\": 15\n}"
            }
          }
        },
        {
          "name": "Scan QR (Student)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/qr/scan/{{qrToken}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{studentToken}}" }]
          }
        },
        {
          "name": "List QR Sessions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/qr/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
